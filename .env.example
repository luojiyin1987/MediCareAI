# 环境变量配置
# 复制此文件为 .env 并填入实际值

# 数据库配置
POSTGRES_PASSWORD=your_secure_postgres_password

# Redis配置
REDIS_PASSWORD=your_secure_redis_password

# JWT配置
JWT_SECRET_KEY=your_jwt_secret_key_at_least_32_characters_long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MinerU API配置
# 请替换为您的实际 MinerU Token
MINERU_TOKEN=your_mineru_token_here

# AI API配置
# 请替换为您的实际 AI API 配置
AI_API_KEY=your_ai_api_key_here
AI_API_URL=http://your_ai_server:port/v1/
AI_MODEL_ID=unsloth/GLM-4.7-Flash-GGUF:BF16

# 文件上传配置
MAX_FILE_SIZE=200000000  # 200MB
UPLOAD_PATH=/app/uploads

# 安全配置
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 开发环境配置
DEBUG=false
# 开发环境配置
DEBUG=false
TESTING=false

# API密钥加密主密钥
API_KEY_MASTER_KEY=your_secure_random_key_here

# =============================================================================
# 邮件服务配置 (可选) | Email Service Configuration (Optional)
# =============================================================================
# 注意：邮件服务也可以通过管理员界面动态配置
# Note: Email service can also be configured dynamically via admin interface
#
# 如果使用管理员界面配置，以下环境变量可以留空
# If using admin interface configuration, these environment variables can be left empty

# SMTP服务器地址 | SMTP Server Host
# SMTP_HOST=smtp.gmail.com

# SMTP端口 | SMTP Port (通常 587 或 465)
# SMTP_PORT=587

# SMTP用户名 | SMTP Username (通常是邮箱地址)
# SMTP_USER=your-email@gmail.com

# SMTP密码或应用专用密码 | SMTP Password or App-Specific Password
# SMTP_PASSWORD=your-app-password

# 发件人邮箱 | From Email Address
# SMTP_FROM_EMAIL=noreply@medicare.ai

# 发件人名称 | From Name
# SMTP_FROM_NAME=MediCareAI

# 使用TLS加密 | Use TLS Encryption (true/false)
# SMTP_USE_TLS=true

# 前端URL (用于邮件中的链接) | Frontend URL (for links in emails)
# FRONTEND_URL=http://localhost:5173
# API密钥加密主密钥
API_KEY_MASTER_KEY=your_secure_random_key_here